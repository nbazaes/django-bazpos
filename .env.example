# ==============================================================================
# BazPOS - Local Development Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values for local dev.
# Never commit .env to git (already in .gitignore).
# For Docker production deployment, use .env.production.example instead.

# Django Settings
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
# Add your LAN IP (e.g. 192.168.1.50) for access from other PCs on the network
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS - frontend origins allowed to call the API
# Add frontend dev server origins (local + LAN IPs) and production origins
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Database Configuration
# Keep DB_HOST as 127.0.0.1 — never expose MySQL to the network
# ------------------------------------------------------------------------------
DB_NAME=bazpos_db
DB_USER=root
DB_PASSWORD=your-mysql-password-here
DB_HOST=127.0.0.1
DB_PORT=3306
