# Frontend environment variables.
# Copy this file to `.env` and adjust for your deployment.

# API base URL.
# In production (server serves the SPA), leave this empty or use a relative path
# so requests stay on the same origin as the HTML.
# Example production value: VITE_API_BASE_URL=/api
# Example local dev value:  VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_BASE_URL=/api

# Backend base URL (used for admin redirects and media links).
# In production leave this empty to use same-origin paths.
# Example production value: VITE_BACKEND_URL=
# Example local dev value:  VITE_BACKEND_URL=http://localhost:8000
VITE_BACKEND_URL=

# Store name displayed in the UI.
VITE_STORE_NAME=BAZPOS
