# Backend environment variables for Docker production.
# Copy this file to `.env` and fill in real secrets before running docker compose up.

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Generate a strong secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-a-new-secret-key

# Never use DEBUG=True in production.
DJANGO_DEBUG=False

# Comma-separated list of hosts/domains that can serve the site.
# Include the Tailscale Magic DNS name and any LAN IP used for direct access.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# CORS / CSRF
# -----------------------------------------------------------------------------
# With the SPA served from the same nginx origin, leave these empty.
# Only fill them if you want to allow direct API access from another origin.
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# -----------------------------------------------------------------------------
# Database (MariaDB container)
# -----------------------------------------------------------------------------
DB_NAME=bazpos_db
DB_USER=bazpos
DB_PASSWORD=secure-db-password
DB_HOST=db
DB_PORT=3306

# -----------------------------------------------------------------------------
# Initial Django superuser
# -----------------------------------------------------------------------------
ADMIN_USER=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=secure-admin-password

# -----------------------------------------------------------------------------
# MariaDB container root credentials
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=secure-root-password
MYSQL_DATABASE=bazpos_db
MYSQL_USER=bazpos
MYSQL_PASSWORD=secure-db-password

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Store name displayed in the UI (sidebar, login, page titles, version footer).
# Passed to the nginx build stage as a Docker build arg.
VITE_STORE_NAME=BAZPOS
